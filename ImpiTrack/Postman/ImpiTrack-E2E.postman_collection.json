{
  "info": {
    "_postman_id": "d6cf9979-a530-4f32-927d-7a1e9135b765",
    "name": "ImpiTrack E2E",
    "description": "Flujo end-to-end para auth, cuenta de usuario y administracion de planes/GPS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"{{testUserName}}\",\n  \"email\": \"{{testUserEmail}}\",\n  \"password\": \"{{testUserPassword}}\",\n  \"fullName\": \"{{testUserFullName}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.expect(body.status).to.eql(1);",
              "pm.expect(body.registration).to.exist;",
              "pm.environment.set('testUserId', body.registration.userId);",
              "pm.environment.set('testEmailVerificationToken', body.registration.emailVerificationToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Verify Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{testUserId}}\",\n  \"token\": \"{{testEmailVerificationToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/verify-email",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "verify-email"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
