{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "Postgres": "",
    "IdentitySqlServer": "",
    "IdentityPostgres": ""
  },
  "Jwt": {
    "Issuer": "ImpiTrack",
    "Audience": "ImpiTrack.Api",
    "SigningKey": "imptrack-dev-signing-key-change-me-2026",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "IdentityStorage": {
    "Provider": "InMemory",
    "ConnectionString": ""
  },
  "IdentityBootstrap": {
    "SeedAdminOnStart": false,
    "AdminUserName": "admin",
    "AdminEmail": "admin@imptrack.local",
    "AdminPassword": "ChangeMe!123",
    "AdminRole": "Admin",
    "UserRole": "User"
  },
  "Email": {
    "Enabled": false,
    "FromName": "ImpiTrack",
    "FromEmail": "no-reply@imptrack.local",
    "VerifyEmailBaseUrl": "https://localhost:5001/api/auth/verify-email/confirm",
    "ResetPasswordBaseUrl": "https://localhost:4200/auth/reset-password",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseSsl": true,
      "UserName": "",
      "Password": ""
    }
  },
  "EmailDispatch": {
    "ChannelCapacity": 1000,
    "EnqueueTimeoutMs": 1000
  },
  "Database": {
    "Provider": "InMemory",
    "ConnectionString": "",
    "CommandTimeoutSeconds": 15,
    "EnableAutoMigrate": false
  },
  "EventBus": {
    "Provider": "InMemory",
    "Host": "127.0.0.1",
    "Port": 1883,
    "ClientId": "imptrack-api",
    "Username": "",
    "Password": "",
    "UseTls": false,
    "TelemetryQoS": 1,
    "StatusQoS": 1,
    "DlqQoS": 1,
    "MaxPublishRetries": 3,
    "RetryBackoffMs": 500,
    "EnableDlq": true
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": "http://127.0.0.1:4317"
  },
  "AllowedHosts": "*"
}
