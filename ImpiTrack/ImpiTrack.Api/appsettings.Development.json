{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Enrichers.Environment", "Serilog.Enrichers.Process", "Serilog.Enrichers.Thread" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} <TraceId:{TraceId}> {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/imptrack-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} <TraceId:{TraceId}> {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "SqlServer": "Data Source=SANTIAGO;Initial Catalog=ImpiTrakDB;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False;",
    "Postgres": "Host=localhost;Port=5432;Database=imptrack;Username=impitrack_app;Password=ChangeMe!123",
    "IdentitySqlServer": "Data Source=SANTIAGO;Initial Catalog=ImpiTrakDB;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True;Application Intent=ReadWrite;Multi Subnet Failover=False;",
    "IdentityPostgres": "Host=localhost;Port=5432;Database=imptrack;Username=impitrack_app;Password=ChangeMe!123"
  },
  "Jwt": {
    "Issuer": "ImpiTrack",
    "Audience": "ImpiTrack.Api",
    "SigningKey": "imptrack-dev-signing-key-change-me-2026",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "IdentityStorage": {
    "Provider": "SqlServer",
    //"Provider": "Postgres",
    "ConnectionString": ""
  },
  "IdentityBootstrap": {
    "SeedAdminOnStart": true,
    "AdminUserName": "admin",
    "AdminEmail": "admin@imptrack.local",
    "AdminPassword": "ChangeMe!123",
    "AdminRole": "Admin",
    "UserRole": "User"
  },
  "Email": {
    "Enabled": true,
    "FromName": "ImpiTrack",
    "FromEmail": "no-reply@imptrack.local",
    "VerifyEmailBaseUrl": "https://localhost:54124/api/auth/verify-email/confirm",
    "ResetPasswordBaseUrl": "http://localhost:4200/auth/reset-password",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "UseSsl": true,
      "UserName": "",
      "Password": ""
    }
  },
  "EmailDispatch": {
    "ChannelCapacity": 1000,
    "EnqueueTimeoutMs": 1000
  },
  "Database": {
    "Provider": "SqlServer",
    //"Provider": "Postgres",
    "ConnectionString": "",
    "CommandTimeoutSeconds": 30,
    "EnableAutoMigrate": true
  },
  "EventBus": {
    "Provider": "InMemory",
    "Host": "127.0.0.1",
    "Port": 1883,
    "ClientId": "imptrack-api-dev",
    "Username": "",
    "Password": "",
    "UseTls": false,
    "TelemetryQoS": 1,
    "StatusQoS": 1,
    "DlqQoS": 1,
    "MaxPublishRetries": 3,
    "RetryBackoffMs": 500,
    "EnableDlq": true
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": "http://127.0.0.1:4317"
  },
  "TcpServerConfig": {
    "Servers": [
      {
        "Name": "CobanTrack",
        "Port": 5001,
        "Protocol": "COBAN"
      }
    ],
    "Socket": {
      "ReceiveBufferBytes": 8192,
      "MaxFrameBytes": 16384,
      "ReadTimeoutSeconds": 30,
      "IdleTimeoutSeconds": 180,
      "HandshakeTimeoutSeconds": 15
    },
    "Pipeline": {
      "ChannelCapacity": 20000,
      "ConsumerWorkers": 2,
      "RawChannelCapacity": 20000,
      "RawConsumerWorkers": 2,
      "RawFullMode": "Wait"
    },
    "Security": {
      "MaxFramesPerMinutePerIp": 600,
      "InvalidFrameThreshold": 40,
      "BanMinutes": 15
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://localhost:3000" ]
  }
}
