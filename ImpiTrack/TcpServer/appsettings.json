{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "SqlServer": "",
    "Postgres": ""
  },
  "TcpServerConfig": {
    "Servers": [
      {
        "Name": "CobanTrack",
        "Port": 5001,
        "Protocol": "COBAN"
      }
    ],
    "Socket": {
      "ReceiveBufferBytes": 8192,
      "MaxFrameBytes": 16384,
      "ReadTimeoutSeconds": 30,
      "IdleTimeoutSeconds": 180,
      "HandshakeTimeoutSeconds": 15
    },
    "Pipeline": {
      "ChannelCapacity": 20000,
      "ConsumerWorkers": 2,
      "RawChannelCapacity": 20000,
      "RawConsumerWorkers": 2,
      "RawFullMode": "Wait"
    },
    "Security": {
      "MaxFramesPerMinutePerIp": 600,
      "InvalidFrameThreshold": 40,
      "BanMinutes": 15
    }
  },
  "Database": {
    "Provider": "InMemory",
    "ConnectionString": "",
    "CommandTimeoutSeconds": 15,
    "EnableAutoMigrate": false
  },
  "EventBus": {
    "Provider": "InMemory",
    "Host": "127.0.0.1",
    "Port": 1883,
    "ClientId": "imptrack-worker",
    "Username": "",
    "Password": "",
    "UseTls": false,
    "TelemetryQoS": 1,
    "StatusQoS": 1,
    "DlqQoS": 1,
    "MaxPublishRetries": 3,
    "RetryBackoffMs": 500,
    "EnableDlq": true,
    "EnablePublishFailureSimulation": false,
    "SimulateFailureEventType": "",
    "SimulateFailureOnce": true
  },
  "OpenTelemetry": {
    "Enabled": false,
    "OtlpEndpoint": "http://127.0.0.1:4317"
  }
}
